		"@types/validator": "13.15.10",
		"cloudflare": "7.0.0",
		"eslint": "10.6.0",
		"eslint-config-prettier": "10.1.8",
		"prettier": "3.9.4",
		"tsx": "4.22.4",
		"typescript": "6.0.3",
		"typescript-eslint": "8.62.1",
		"wrangler": "4.110.0"
